---
import Layout from '@/layouts/Layout.astro';
import HeaderLexara from '@/components/HeaderLexara.astro';
import Footer from '@/components/Footer.astro';
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Badge from '@/components/ui/Badge.astro';

const features = [
  'AI-powered client screening',
  'Automatic conflict detection',
  'Practice area customization',
  'Team collaboration features',
  'Advanced analytics & reporting',
  'Custom branding options',
  'API access for integrations',
  'Priority support',
  'SOC 2 aligned security',
  'HIPAA compliance & BAA',
  'No limit on number of conversations per month',
  'No limit on support staff',
  'You control your firm’s data'
];

const pricingExamples = [
  {
    attorneys: 1,
    label: 'Solo Practitioner',
    monthly: 75,
    annual: 750,
    popular: false
  },
  {
    attorneys: 3,
    label: 'Small Firm',
    monthly: 175,
    annual: 1750,
    popular: false
  },
  {
    attorneys: 10,
    label: 'Medium Firm',
    monthly: 525,
    annual: 5250,
    popular: false
  },
  {
    attorneys: 25,
    label: 'Large Firm',
    monthly: 1275,
    annual: 12750,
    popular: false
  }
];

const faqs = [
  {
    question: "How does per-attorney pricing work?",
    answer: "Your first attorney is $75/month, and each additional attorney is $50/month. For example, a 5-attorney firm would pay $75 + (4 × $50) = $275/month. When you pay annually, you save 2 months of fees."
  },
  {
    question: "What's included in the free trial?",
    answer: "Your 30-day free trial includes full access to all features for your entire team, including AI conversations, conflict detection, analytics, and priority support."
  },
  {
    question: "How much do I save with annual billing?",
    answer: "Annual billing gives you 2 months free. For 1 attorney, you pay $750/year instead of $900. Each additional attorney is $500/year instead of $600. The more attorneys you have, the more you save!"
  },
  {
    question: "Can I add or remove attorneys during my subscription?",
    answer: "Yes! billing will be prorated."
  },
  {
    question: "Can I integrate <em>Engage</em> with my existing systems?",
    answer: "Yes! All plans include API access for seamless integration with practice management software, CRMs, and other legal tech tools. We are continually adding integrations. If you don’t see the integration you want, please contact us at support@lexara.com with “Integration Request” in the subject line."
  },
  {
    question: "Is my client data secure?",
    answer: "Absolutely. We use bank-level encryption, are aligned with SOC 2 standards, and never train our AI on your client data. HIPAA compliance and BAA agreements are available for all customers."
  },
  {
    question: "What if our firm has more than 50 attorneys?",
    answer: "For firms with 50+ attorney, we offer volume discounts. Contact our sales team for a personalized quote and dedicated onboarding, at sales@lexara.com "
  },
  {
    question: "What if our firm has more than 200 attorneys?",
    answer: "For firms with 200+ attorneys, contact us for custom built enterprise solutions. Contact us at sales@lexara.com"
  }
];
---

<Layout title="Pricing - Engage by Lexara">
  <HeaderLexara />
  <main>
    <!-- Hero Section -->
    <Section background="white" padding="large">
      <Container size="medium">
        <div class="text-center">
          <h1 class="text-4xl md:text-5xl font-semibold text-lexara-dark-navy mb-6">
            Simple, Transparent Pricing
          </h1>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-4">
            Only pay for what you need. Priced per attorney and no hidden fees. Less than 1 billable hour a month.
          </p>
          <p class="text-sm text-lexara-dark-navy font-semibold">
            💰 Save 2 months when you pay annually
          </p>
        </div>
      </Container>
    </Section>

    <!-- Pricing Calculator Section -->
    <Section background="dark-navy" padding="xlarge">
      <Container size="medium">
        <!-- Billing Toggle -->
        <div class="flex justify-center mb-12">
          <div class="inline-flex items-center bg-lexara-white-smoke rounded-full p-1">
            <button 
              id="monthly-toggle"
              class="px-6 py-2 rounded-full text-sm font-semibold transition-all duration-200 bg-lexara-dark-navy text-white"
            >
              Monthly
            </button>
            <button 
              id="annual-toggle"
              class="px-6 py-2 rounded-full text-sm font-semibold transition-all duration-200 text-lexara-dark-navy"
            >
              Annual
              <span class="ml-2 text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">Save 17%</span>
            </button>
          </div>
        </div>

        <!-- Main Pricing Card -->
        <div class="bg-lexara-white-smoke rounded-2xl p-8 md:p-12 mb-8">
          <div class="grid md:grid-cols-2 gap-12">
            <!-- Pricing Details -->
            <div>
              <h2 class="text-3xl font-semibold text-lexara-dark-navy mb-6">
                Per-Attorney Pricing
              </h2>
              
              <div class="space-y-6 mb-8">
                <div class="border-b border-gray-200 pb-6">
                  <div class="flex items-baseline justify-between mb-2">
                    <span class="text-lg text-gray-700">First attorney</span>
                    <div class="text-right">
                      <span class="text-3xl font-bold text-lexara-dark-navy monthly-price">$75</span>
                      <span class="text-3xl font-bold text-lexara-dark-navy annual-price hidden">$750</span>
                      <span class="text-gray-600 ml-1 monthly-period">/month</span>
                      <span class="text-gray-600 ml-1 annual-period hidden">/year</span>
                    </div>
                  </div>
                </div>
                
                <div class="border-b border-gray-200 pb-6">
                  <div class="flex items-baseline justify-between mb-2">
                    <span class="text-lg text-gray-700">Each additional attorney</span>
                    <div class="text-right">
                      <span class="text-3xl font-bold text-lexara-dark-navy monthly-price">$50</span>
                      <span class="text-3xl font-bold text-lexara-dark-navy annual-price hidden">$500</span>
                      <span class="text-gray-600 ml-1 monthly-period">/month</span>
                      <span class="text-gray-600 ml-1 annual-period hidden">/year</span>
                    </div>
                  </div>
                </div>
              </div>

              <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
                <p class="text-sm text-blue-900">
                  <strong>Annual savings:</strong> When paid annually, receive 2 months of free service. 
                  Save $150/year on your first attorney and $100/year on each additional attorney.
                </p>
              </div>

              <Button 
                href="https://console.lexara.app/signup?utm_source=pricing&utm_campaign=main_cta"
                class="w-full !bg-lexara-dark-navy !text-white hover:!bg-lexara-light-navy"
                size="large"
              >
                Start Free Trial
              </Button>
            </div>

            <!-- Features List -->
            <div>
              <h3 class="text-xl font-semibold text-lexara-dark-navy mb-6">
                Everything Included
              </h3>
              <ul class="space-y-3">
                {features.map((feature) => (
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-gray-700">{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <!-- Pricing Examples -->
        <div class="text-center mb-8">
          <h3 class="text-2xl font-semibold text-white mb-8">
            Price per Attorney, Not Per Seat
          </h3>
        </div>

        <div class="text-center mt-8">
          <p class="text-gray-300 text-sm">
            Need pricing for 50+ attorneys? 
            <a href="https://console.lexara.app/contact-sales" class="text-white underline hover:text-gray-100">
              Contact sales for volume discounts
            </a>
          </p>
        </div>
      </Container>
    </Section>

    <!-- FAQ Section -->
    <Section background="white" padding="xlarge">
      <Container size="medium">
        <h2 class="text-3xl font-semibold text-center text-lexara-dark-navy mb-12">
          Frequently Asked Questions
        </h2>
        
        <div class="space-y-1">
          {faqs.map((faq, index) => (
            <details class="group border-b border-gray-200">
              <summary class="py-6 px-4 cursor-pointer list-none flex items-center justify-between hover:bg-gray-50 transition-colors">
                <h3 class="font-semibold text-lexara-dark-navy pr-8" set:html={faq.question}></h3>
                <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-4 pb-6 text-gray-600">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </Container>
    </Section>

    <!-- CTA Section -->
    <Section background="dark-navy" padding="xlarge">
      <Container size="medium">
        <div class="text-center">
          <h2 class="text-3xl font-semibold text-white mb-4">
            Ready to Get Started?
          </h2>
          <p class="text-lg text-gray-300 mb-8">
            Join hundreds of law firms saving billable hours every week.
          </p>
          <Button 
            href="https://console.lexara.app/signup?utm_source=pricing&utm_campaign=bottom_cta"
            class="!bg-white !text-lexara-dark-navy hover:!bg-gray-100"
            size="large"
          >
            Start Free Trial
          </Button>
          <p class="text-sm text-gray-300 mt-4">
            Join today • Cancel anytime
          </p>
        </div>
      </Container>
    </Section>
  </main>
  <Footer />
</Layout>

<script is:inline>
  // Billing toggle functionality
  document.addEventListener('DOMContentLoaded', () => {
    const monthlyToggle = document.getElementById('monthly-toggle');
    const annualToggle = document.getElementById('annual-toggle');
    const monthlyPrices = document.querySelectorAll('.monthly-price');
    const annualPrices = document.querySelectorAll('.annual-price');
    const monthlyPeriods = document.querySelectorAll('.monthly-period');
    const annualPeriods = document.querySelectorAll('.annual-period');

    function showMonthly() {
      monthlyToggle.classList.add('bg-lexara-dark-navy', 'text-white');
      monthlyToggle.classList.remove('text-lexara-dark-navy');
      annualToggle.classList.remove('bg-lexara-dark-navy', 'text-white');
      annualToggle.classList.add('text-lexara-dark-navy');
      
      monthlyPrices.forEach(el => el.classList.remove('hidden'));
      annualPrices.forEach(el => el.classList.add('hidden'));
      monthlyPeriods.forEach(el => el.classList.remove('hidden'));
      annualPeriods.forEach(el => el.classList.add('hidden'));
    }

    function showAnnual() {
      annualToggle.classList.add('bg-lexara-dark-navy', 'text-white');
      annualToggle.classList.remove('text-lexara-dark-navy');
      monthlyToggle.classList.remove('bg-lexara-dark-navy', 'text-white');
      monthlyToggle.classList.add('text-lexara-dark-navy');
      
      monthlyPrices.forEach(el => el.classList.add('hidden'));
      annualPrices.forEach(el => el.classList.remove('hidden'));
      monthlyPeriods.forEach(el => el.classList.add('hidden'));
      annualPeriods.forEach(el => el.classList.remove('hidden'));
    }

    monthlyToggle.addEventListener('click', () => {
      showMonthly();
      if (window.logClick) {
        window.logClick('billing_toggle', { period: 'monthly' });
      }
    });

    annualToggle.addEventListener('click', () => {
      showAnnual();
      if (window.logClick) {
        window.logClick('billing_toggle', { period: 'annual' });
      }
    });

    // Track pricing CTA clicks
    document.querySelectorAll('a[href*="signup"]').forEach(link => {
      link.addEventListener('click', () => {
        if (window.logClick) {
          const isAnnual = !annualPrices[0]?.classList.contains('hidden');
          window.logClick('pricing_cta', {
            billing_period: isAnnual ? 'annual' : 'monthly',
            location: link.closest('section')?.querySelector('h2')?.textContent || 'pricing_section'
          });
        }
      });
    });

    // Track FAQ interactions
    document.querySelectorAll('details').forEach((detail, index) => {
      detail.addEventListener('toggle', () => {
        if (detail.open && window.logClick) {
          window.logClick('faq_expand', {
            question: detail.querySelector('h3')?.textContent,
            index: index
          });
        }
      });
    });
  });
</script>